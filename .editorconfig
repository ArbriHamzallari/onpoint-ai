root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csx}]
indent_size = 4

[*.{ts,tsx,js,jsx,json,jsonc,yml,yaml,html,css,scss}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{sln,csproj,props,targets}]
end_of_line = crlf
indent_size = 2

[*.{cmd,bat,ps1}]
end_of_line = crlf
