{
  "Serilog": {
    "Using":  [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=onpoint_db;Username=onpoint;Password=onpoint123"
  },
  "Jwt": {
    "Secret": "dev-secret-replace-with-64-char-random-string-before-production!!",
    "Issuer": "onpoint-api",
    "Audience": "onpoint-clients",
    "ExpiryMinutes": "60"
  },
  "AppSettings": {
    "BaseUrl": "http://localhost:5000"
  },
  "AiService": {
    "BaseUrl": "http://localhost:5200",
    "TimeoutSeconds": 10
  }
}
