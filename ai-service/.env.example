ANTHROPIC_API_KEY=

# Model identifiers
MODEL_GPT_4O_MINI=gpt-4o-mini
MODEL_HAIKU=claude-haiku-4-5-20251001

# A/B traffic split — percent of business_ids routed to Haiku (default 35)
HAIKU_TRAFFIC_PCT=35

# Service config
LOG_LEVEL=INFO
ENVIRONMENT=development
